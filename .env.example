MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/abhishek-learns

# Admin auth
# The password required to access /admin pages and edit content.
# IMPORTANT: wrap in double quotes if it contains special chars like # or spaces.
ADMIN_PASSWORD="change-me"
# Secret used to sign the 30-day admin session token. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=change-me-to-a-long-random-string

# Optional — Vercel sets VERCEL_URL automatically; only set this for a custom domain:
# NEXT_PUBLIC_APP_URL=https://your-domain.com
